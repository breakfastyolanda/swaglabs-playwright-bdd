{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
   "moduleResolution": "node",
   "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  
  },
  "include": [
    "features/**/*.ts",
    "pages/**/*.ts",
    "support/**/*.ts"
  ]
}